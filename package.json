{
  "name": "stashcat-api",
  "version": "1.0.0",
  "description": "TypeScript API client for Stashcat messenger (schul.cloud version)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prepare": "tsc",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "clean": "rm -rf dist",
    "test:api": "ts-node --transpile-only scripts/test-api.ts"
  },
  "keywords": [
    "stashcat",
    "schul.cloud",
    "messenger",
    "api",
    "typescript"
  ],
  "author": "Cline",
  "license": "MIT",
  "devDependencies": {
    "@types/form-data": "^2.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.12.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.7",
    "form-data": "^4.0.0",
    "socket.io-client": "^4.8.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.ts"
    ]
  }
}
