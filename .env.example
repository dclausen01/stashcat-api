# Stashcat API Configuration
STASHCAT_BASE_URL=https://api.stashcat.com/
# STASHCAT_BASE_URL=https://api.schul.cloud/  # For schul.cloud variant

# Authentication (required)
STASHCAT_EMAIL=your-email@example.com
STASHCAT_PASSWORD=your-password
STASHCAT_APP_NAME=stashcat-api-client

# Optional: Custom device ID (auto-generated if not provided)
# STASHCAT_DEVICE_ID=your-custom-device-id

# ── Test-Skript (scripts/test-api.ts) ───────────────────────────────────────
# IDs für tiefere API-Tests (alle optional)
# TEST_COMPANY_ID=      # Company-ID → aktiviert Channel-Tests
# TEST_CHANNEL_ID=      # Channel-ID (alternativ zu TEST_COMPANY_ID)
# TEST_CONVERSATION_ID= # Conversation-ID (sonst wird erste gefundene genutzt)
# TEST_USER_ID=         # User-ID für getUserInfo()-Test

# Pfad zu einer lokalen Datei für den Upload-Test (optional)
# TEST_UPLOAD_FILE=/pfad/zur/datei.pdf

# Schreibende Account-Aktionen (changeStatus) ausführen (Standard: aus)
# TEST_RUN_WRITE=1
